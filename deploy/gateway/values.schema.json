{
  "$schema": "https://json-schema.org/schema#",
  "type": "object",
  "title": "JSON schema for Twingate Gateway Helm Chart values",
  "required": ["twingate", "tls"],
  "properties": {
    "twingate": {
      "type": "object",
      "required": ["network"],
      "properties": {
        "network": {
          "type": "string",
          "description": "The name of the Twingate network to use."
        },
        "host": {
          "type": "string",
          "description": "Twingate host.",
          "default": "twingate.com"
        },
        "resource": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable TwingateResource CRD integration."
            },
            "extraAnnotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Extra annotations to add to the ClusterIP service."
            }
          }
        }
      },
      "additionalProperties": false
    },
    "auditLog": {
      "type": "object",
      "properties": {
        "flushInterval": {
          "type": "string",
          "description": "Interval at which audit logs are flushed (e.g., 5m, 30s).",
          "default": "5m"
        },
        "flushSizeThreshold": {
          "type": "integer",
          "description": "Size threshold (in bytes) at which audit logs are flushed.",
          "default": 1000000
        }
      },
      "additionalProperties": false
    },
    "kubernetes": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Kubernetes API server proxying.",
          "default": false
        },
        "upstreams": {
          "type": "array",
          "description": "External-cluster credentials (testing only). Leave empty to use the pod's service account.",
          "items": {
            "type": "object",
            "required": ["name", "caFile"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the upstream."
              },
              "bearerToken": {
                "type": "string",
                "description": "Bearer token for authenticating to the Kubernetes API server."
              },
              "bearerTokenFile": {
                "type": "string",
                "description": "Path to file containing bearer token for authenticating to the Kubernetes API server."
              },
              "caFile": {
                "type": "string",
                "description": "Path to CA certificate file for verifying the Kubernetes API server's TLS certificate."
              }
            },
            "oneOf": [
              {"required": ["bearerToken"]},
              {"required": ["bearerTokenFile"]}
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "ssh": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable SSH proxying.",
          "default": false
        },
        "gateway": {
          "type": "object",
          "description": "Gateway SSH configuration.",
          "properties": {
            "username": {
              "type": "string",
              "description": "Username used for all upstream SSH connections."
            },
            "key": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Key type: ed25519, ecdsa, rsa.",
                  "default": "ed25519"
                },
                "bits": {
                  "type": "integer",
                  "description": "Key bits: ECDSA: 256/384/521, RSA: 2048/3072/4096 (ignored for ed25519).",
                  "default": 0
                }
              },
              "additionalProperties": false
            },
            "hostCertificate": {
              "type": "object",
              "properties": {
                "ttl": {
                  "type": "string",
                  "description": "TTL for host certificates.",
                  "default": "24h"
                }
              },
              "additionalProperties": false
            },
            "userCertificate": {
              "type": "object",
              "properties": {
                "ttl": {
                  "type": "string",
                  "description": "TTL for user certificates.",
                  "default": "5m"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "ca": {
          "type": "object",
          "description": "CA configuration. Exactly one of manual or vault must be configured when SSH is enabled.",
          "properties": {
            "manual": {
              "type": "object",
              "description": "Manual CA configuration.",
              "properties": {
                "existingSecret": {
                  "type": "string",
                  "description": "Name of existing secret containing the CA private key (key name: ca-private-key)."
                },
                "privateKey": {
                  "type": "string",
                  "description": "CA private key content (used if existingSecret is not set)."
                }
              },
              "oneOf": [
                {"required": ["existingSecret"]},
                {"required": ["privateKey"]}
              ],
              "additionalProperties": false
            },
            "vault": {
              "type": "object",
              "description": "Vault CA configuration.",
              "required": ["address", "auth", "role"],
              "properties": {
                "address": {
                  "type": "string",
                  "description": "Vault server address (e.g., https://vault.example.com:8200)."
                },
                "namespace": {
                  "type": "string",
                  "description": "Vault namespace (optional, for Vault Enterprise)."
                },
                "caBundle": {
                  "type": "string",
                  "description": "CA bundle content for verifying Vault's TLS certificate (PEM format). Optional if Vault uses a certificate from the system trust store."
                },
                "existingCABundleSecret": {
                  "type": "string",
                  "description": "Name of existing secret containing CA bundle (key name: ca.crt). Optional if Vault uses a certificate from the system trust store."
                },
                "auth": {
                  "type": "object",
                  "description": "Vault authentication configuration.",
                  "properties": {
                    "existingTokenSecret": {
                      "type": "string",
                      "description": "Name of existing secret containing the Vault token (key name: token)."
                    },
                    "token": {
                      "type": "string",
                      "description": "Vault token."
                    },
                    "appRole": {
                      "type": "object",
                      "description": "AppRole authentication configuration.",
                      "required": ["roleId"],
                      "properties": {
                        "mount": {
                          "type": "string",
                          "description": "AppRole auth mount path (defaults to 'approle').",
                          "default": "approle"
                        },
                        "roleId": {
                          "type": "string",
                          "description": "AppRole Role ID."
                        },
                        "secretId": {
                          "type": "string",
                          "description": "AppRole Secret ID in plaintext string."
                        },
                        "existingSecretIdSecret": {
                          "type": "string",
                          "description": "Name of existing K8s Secret containing the Secret ID (key name: secretId)."
                        }
                      },
                      "oneOf": [
                        { "required": ["secretId"] },
                        { "required": ["existingSecretIdSecret"] }
                      ],
                      "additionalProperties": false
                    }
                  },
                  "oneOf": [
                    { "required": ["existingTokenSecret"] },
                    { "required": ["token"] },
                    { "required": ["appRole"] }
                  ],
                  "additionalProperties": false
                },
                "mount": {
                  "type": "string",
                  "description": "Default SSH mount point (defaults to 'ssh').",
                  "default": "ssh"
                },
                "role": {
                  "type": "string",
                  "description": "Default Vault role for certificate signing."
                },
                "gatewayHostCA": {
                  "type": "object",
                  "description": "Override mount/role for Gateway host certificate signing.",
                  "properties": {
                    "mount": {
                      "type": "string",
                      "description": "SSH mount point for Gateway host CA."
                    },
                    "role": {
                      "type": "string",
                      "description": "Vault role for Gateway host CA."
                    }
                  },
                  "additionalProperties": false
                },
                "gatewayUserCA": {
                  "type": "object",
                  "description": "Override mount/role for Gateway user certificate signing.",
                  "properties": {
                    "mount": {
                      "type": "string",
                      "description": "SSH mount point for Gateway user CA."
                    },
                    "role": {
                      "type": "string",
                      "description": "Vault role for Gateway user CA."
                    }
                  },
                  "additionalProperties": false
                },
                "upstreamHostCA": {
                  "type": "object",
                  "description": "Override mount for upstream host certificate verification.",
                  "properties": {
                    "mount": {
                      "type": "string",
                      "description": "SSH mount point for upstream host CA."
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "if": {
        "properties": {"enabled": {"const": true}},
        "required": ["enabled"]
      },
      "then": {
        "required": ["ca"],
        "properties": {
          "ca": {
            "oneOf": [
              {"required": ["manual"]},
              {"required": ["vault"]}
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "webApp": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable HTTP web app proxying.",
          "default": false
        },
        "headers": {
          "type": "object",
          "description": "Custom HTTP headers to inject into proxied requests. Values may use template expressions with the twingate namespace (e.g. {{twingate.username}}, {{twingate.groups}}, {{twingate.jwt}}, {{twingate.clientGeoLoc}}).",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "tls": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of an existing secret containing TLS certificates."
        },
        "autoGenerated": {
          "description": "TLS auto-generation settings. The boolean form is deprecated; use the object form. Set `certManager.enabled: true` to delegate to cert-manager.",
          "default": {
            "enabled": true
          },
          "oneOf": [
            {
              "type": "boolean",
              "deprecated": true,
              "description": "Deprecated. Use the object form with `tls.autoGenerated.enabled` instead."
            },
            {
              "type": "object",
              "required": ["enabled"],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Whether to provision a TLS certificate."
                },
                "certManager": {
                  "type": "object",
                  "description": "cert-manager settings for the leaf certificate.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Delegate certificate provisioning to cert-manager. Requires `issuerRef.name` and `issuerRef.kind`.",
                      "default": false
                    },
                    "commonName": {
                      "type": "string",
                      "description": "Override the certificate commonName. Defaults to the chart's fullname when empty.",
                      "default": ""
                    },
                    "duration": {
                      "type": "string",
                      "description": "Certificate lifetime (e.g. `2160h`). Leave empty to use the cert-manager default.",
                      "default": ""
                    },
                    "renewBefore": {
                      "type": "string",
                      "description": "How long before expiry to renew (e.g. `360h`). Leave empty to use the cert-manager default.",
                      "default": ""
                    },
                    "issuerRef": {
                      "type": "object",
                      "description": "Reference to an existing Issuer/ClusterIssuer. Required when `certManager.enabled` is true.",
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Name of the issuer resource.",
                          "default": ""
                        },
                        "kind": {
                          "type": "string",
                          "description": "Kind of the issuer resource (e.g. `Issuer`, `ClusterIssuer`, `AWSPCAClusterIssuer`).",
                          "default": "Issuer"
                        },
                        "group": {
                          "type": "string",
                          "description": "API group of the issuer resource. Use a non-default value for out-of-tree issuer plugins (e.g. `awspca.cert-manager.io`).",
                          "default": "cert-manager.io"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "ipAddresses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IP addresses to include as Subject Alternative Names in the TLS certificate."
        },
        "dnsNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "DNS names to include as Subject Alternative Names in the TLS certificate."
        },
        "cert": {
          "type": "string",
          "description": "TLS certificate content (PEM format)."
        },
        "key": {
          "type": "string",
          "description": "TLS private key content (PEM format)."
        },
        "ca": {
          "type": "string",
          "description": "TLS CA certificate (PEM format)."
        }
      },
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "podMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create PodMonitor resource(s) for scraping metrics using PrometheusOperator.",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "The interval at which metrics should be scraped.",
              "default": "30s"
            },
            "scrapeTimeout": {
              "type": "string",
              "description": "The timeout after which the scrape is ended.",
              "default": ""
            },
            "relabelings": {
              "type": "array",
              "description": "Metrics RelabelConfigs to apply to samples before scraping.",
              "default": [],
              "items": {}
            },
            "metricRelabelings": {
              "type": "array",
              "description": "Metrics RelabelConfigs to apply to samples before ingestion.",
              "default": [],
              "items": {}
            },
            "honorLabels": {
              "type": "boolean",
              "description": "Specify honorLabels parameter to add the scrape endpoint.",
              "default": false
            },
            "additionalLabels": {
              "type": "object",
              "description": "Additional labels that can be used so PodMonitor resource(s) can be discovered by Prometheus",
              "default": {}
            }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create ServiceMonitor resource(s) for scraping metrics using PrometheusOperator.",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "The interval at which metrics should be scraped.",
              "default": "30s"
            },
            "scrapeTimeout": {
              "type": "string",
              "description": "The timeout after which the scrape is ended.",
              "default": ""
            },
            "relabelings": {
              "type": "array",
              "description": "Metrics RelabelConfigs to apply to samples before scraping.",
              "default": [],
              "items": {}
            },
            "metricRelabelings": {
              "type": "array",
              "description": "Metrics RelabelConfigs to apply to samples before ingestion.",
              "default": [],
              "items": {}
            },
            "honorLabels": {
              "type": "boolean",
              "description": "Specify honorLabels parameter to add the scrape endpoint.",
              "default": false
            },
            "additionalLabels": {
              "type": "object",
              "description": "Additional labels that can be used so ServiceMonitor resource(s) can be discovered by Prometheus",
              "default": {}
            }
          }
        },
        "grafanaDashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create Grafana Dashboard for Gateway.",
              "default": false
            },
            "labels": {
              "type": "object",
              "description": "Labels that can be used to auto-discover and provision dashboards from ConfigMaps by Grafana.",
              "default": {
                "grafana_dashboard": "1"
              }
            }
          }
        },
        "prometheusRule": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a PrometheusRule resource for defining alerting rules.",
              "default": false
            },
            "rules": {
              "type": "array",
              "description": "Custom Prometheus alerting rules.",
              "default": [],
              "items": {}
            },
            "additionalLabels": {
              "type": "object",
              "description": "Additional labels for the PrometheusRule resource.",
              "default": {}
            }
          }
        }
      },
      "additionalProperties": false
    },
    "extraObjects": {
      "type": "array",
      "description": "Extra Kubernetes manifests to render alongside the chart's resources. Each entry may be a YAML object or a string (multi-document YAML); both are passed through `tpl` so release values are interpolated.",
      "default": [],
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": true
          },
          {
            "type": "string"
          }
        ]
      }
    }
  }
}
